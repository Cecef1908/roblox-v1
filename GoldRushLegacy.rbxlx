      </Item>
      <Item class="ModuleScript" referent="25">
        <Properties>
          <string name="Name">MapBuilder</string>
          <string name="Source"><![CDATA[--[[
    MapBuilder.lua (ModuleScript)
    ROLE : Génère le monde au runtime : terrain, ville, zones de minage,
           NPCs marchands, templates de gisements, remote events.
    APPELÉ PAR : GameManager:Init() en tout premier.
]]

local MapBuilder = {}

local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ZoneConfig = require(ReplicatedStorage.Modules.Config.ZoneConfig)

-- ═══════════════════════════════════════════
-- COULEURS
-- ═══════════════════════════════════════════
local C = {
    grass      = Color3.fromRGB(76, 140, 53),
    dirt       = Color3.fromRGB(120, 85, 50),
    road       = Color3.fromRGB(75, 70, 60),
    water      = Color3.fromRGB(50, 120, 180),
    waterDeep  = Color3.fromRGB(30, 80, 140),
    sand       = Color3.fromRGB(210, 190, 140),
    wood       = Color3.fromRGB(130, 85, 45),
    woodDark   = Color3.fromRGB(90, 60, 30),
    stone      = Color3.fromRGB(140, 135, 125),
    stoneDark  = Color3.fromRGB(100, 95, 85),
    roof       = Color3.fromRGB(160, 80, 40),
    gold       = Color3.fromRGB(255, 215, 0),
    sign       = Color3.fromRGB(180, 140, 60),
    tent       = Color3.fromRGB(200, 180, 140),
}

-- ═══════════════════════════════════════════
-- HELPERS
-- ═══════════════════════════════════════════
local function makePart(props)
    local p = Instance.new("Part")
    p.Anchored = true
    p.TopSurface = Enum.SurfaceType.Smooth
    p.BottomSurface = Enum.SurfaceType.Smooth
    for k, v in pairs(props) do
        if k ~= "Parent" then
            p[k] = v
        end
    end
    p.Parent = props.Parent or Workspace
    return p
end

local function makeWall(name, size, position, color, parent)
    return makePart({
        Name = name,
        Size = size,
        Position = position,
        Color = color,
        Material = Enum.Material.SmoothPlastic,
        Parent = parent,
    })
end

local function addBillboard(parent, text, color, offset)
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(0, 250, 0, 50)
    gui.StudsOffset = offset or Vector3.new(0, 4, 0)
    gui.AlwaysOnTop = true
    gui.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color or Color3.new(1, 1, 1)
    label.TextStrokeTransparency = 0.5
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = gui
    return gui
end

-- ═══════════════════════════════════════════
-- INIT
-- ═══════════════════════════════════════════
function MapBuilder:Init()
    print("[MapBuilder] Construction du monde...")
    self:CreateRemoteEvents()
    self:CreateFolders()
    self:CreateTemplates()
    self:CreateItemModels()
    self:CreateWorld()
    print("[MapBuilder] Monde construit ✓")
end

-- ═══════════════════════════════════════════
-- REMOTE EVENTS
-- ═══════════════════════════════════════════
function MapBuilder:CreateRemoteEvents()
    local eventsFolder = Instance.new("Folder")
    eventsFolder.Name = "Events"
    eventsFolder.Parent = ReplicatedStorage

    local remoteEvents = Instance.new("Folder")
    remoteEvents.Name = "RemoteEvents"
    remoteEvents.Parent = eventsFolder

    local eventNames = {
        -- Mining
        "RequestMine", "MineResult",
        "StartBateeMinigame", "BateeMinigameResult",
        -- Player data
        "InitPlayerData", "PlayerDataUpdated",
        -- Notifications
        "NotifyPlayer", "LevelUp",
        -- Day/Night
        "TimeOfDayChanged",
        -- Tutorial
        "StartTutorial",
        -- Economy
        "RequestSell", "SellResult",
        "RequestBuyTool", "RequestUpgradeTool", "ShopResult",
    }

    for _, name in ipairs(eventNames) do
        local event = Instance.new("RemoteEvent")
        event.Name = name
        event.Parent = remoteEvents
    end

    print("[MapBuilder] " .. #eventNames .. " RemoteEvents créés")
end

-- ═══════════════════════════════════════════
-- DOSSIERS WORKSPACE
-- ═══════════════════════════════════════════
function MapBuilder:CreateFolders()
    -- ActiveGoldDeposits — où les gisements spawnent
    local deposits = Instance.new("Folder")
    deposits.Name = "ActiveGoldDeposits"
    deposits.Parent = Workspace

    -- Map — contient les zones avec spawn points
    local map = Instance.new("Folder")
    map.Name = "Map"
    map.Parent = Workspace

    -- Zone 1
    local z1 = Instance.new("Folder")
    z1.Name = "Zone1_RiviereTransquille"
    z1.Parent = map

    local z1sp = Instance.new("Folder")
    z1sp.Name = "SpawnPoints"
    z1sp.Parent = z1

    -- Zone 2
    local z2 = Instance.new("Folder")
    z2.Name = "Zone2_CollinesAmbrees"
    z2.Parent = map

    local z2sp = Instance.new("Folder")
    z2sp.Name = "SpawnPoints"
    z2sp.Parent = z2

    -- Zone 3
    local z3 = Instance.new("Folder")
    z3.Name = "Zone3_MineCrowCreek"
    z3.Parent = map

    local z3sp = Instance.new("Folder")
    z3sp.Name = "SpawnPoints"
    z3sp.Parent = z3

    -- Créer les spawn points dans chaque zone
    self:CreateSpawnPoints("Zone1", z1sp, ZoneConfig.Zones.Zone1)
    self:CreateSpawnPoints("Zone2", z2sp, ZoneConfig.Zones.Zone2)
    self:CreateSpawnPoints("Zone3", z3sp, ZoneConfig.Zones.Zone3)
end

function MapBuilder:CreateSpawnPoints(zoneId, parentFolder, zoneData)
    local center = zoneData.WorldPosition
    local count = zoneData.MaxActiveDeposits + 4 -- quelques extras

    for i = 1, count do
        local angle = (i / count) * math.pi * 2 + math.random() * 0.5
        local radius = 15 + math.random() * 25
        local x = center.X + math.cos(angle) * radius
        local z = center.Z + math.sin(angle) * radius

        local pt = makePart({
            Name = "SP_" .. i,
            Size = Vector3.new(3, 0.1, 3),
            Position = Vector3.new(x, 1.5, z),
            Transparency = 1,
            CanCollide = false,
            Anchored = true,
            Parent = parentFolder,
        })
        pt:SetAttribute("ZoneId", zoneId)
    end

    print("[MapBuilder] " .. count .. " spawn points dans " .. zoneId)
end

-- ═══════════════════════════════════════════
-- TEMPLATES (ServerStorage)
-- ═══════════════════════════════════════════
function MapBuilder:CreateTemplates()
    local templates = Instance.new("Folder")
    templates.Name = "Templates"
    templates.Parent = ServerStorage

    -- GoldDeposit_Paillette (Zone 1 — petit éclat doré)
    local paillette = makePart({
        Name = "GoldDeposit_Paillette",
        Size = Vector3.new(3, 0.5, 3),
        Color = C.gold,
        Material = Enum.Material.Neon,
        Transparency = 0.2,
        Shape = Enum.PartType.Block,
        CanCollide = false,
        Parent = templates,
    })
    self:AddGoldParticles(paillette, 5, 0.2)

    -- Beacon lumineux pour Paillette
    local beaconP = Instance.new("Part")
    beaconP.Name = "Beacon"
    beaconP.Anchored = true
    beaconP.CanCollide = false
    beaconP.Size = Vector3.new(0.3, 10, 0.3)
    beaconP.CFrame = CFrame.new(0, 5, 0)
    beaconP.Color = C.gold
    beaconP.Material = Enum.Material.Neon
    beaconP.Transparency = 0.6
    beaconP.Parent = paillette

    -- GoldDeposit_Pepite (Zone 2 — nugget moyen)
    local pepite = makePart({
        Name = "GoldDeposit_Pepite",
        Size = Vector3.new(2.5, 1.5, 2),
        Color = Color3.fromRGB(218, 165, 32),
        Material = Enum.Material.Metal,
        Shape = Enum.PartType.Block,
        CanCollide = false,
        Parent = templates,
    })
    self:AddGoldParticles(pepite, 8, 0.3)

    -- GoldDeposit_Filon (Zone 2-3 — veine dans la roche)
    local filon = makePart({
        Name = "GoldDeposit_Filon",
        Size = Vector3.new(4, 3, 2),
        Color = Color3.fromRGB(160, 140, 60),
        Material = Enum.Material.Rock,
        Shape = Enum.PartType.Block,
        CanCollide = false,
        Parent = templates,
    })
    -- Veine dorée intégrée
    local vein = Instance.new("Part")
    vein.Name = "GoldVein"
    vein.Anchored = true
    vein.CanCollide = false
    vein.Size = Vector3.new(3.5, 0.5, 2.1)
    vein.CFrame = CFrame.new(0, 0.5, 0)
    vein.Color = C.gold
    vein.Material = Enum.Material.Neon
    vein.Transparency = 0.3
    vein.Parent = filon
    self:AddGoldParticles(filon, 10, 0.4)

    -- Gem_Quartz
    local quartz = makePart({
        Name = "Gem_Quartz",
        Size = Vector3.new(1.5, 2.5, 1.5),
        Color = Color3.fromRGB(240, 240, 255),
        Material = Enum.Material.Neon,
        Transparency = 0.3,
        CanCollide = false,
        Parent = templates,
    })

    -- Gem_Amethyste
    local amethyste = makePart({
        Name = "Gem_Amethyste",
        Size = Vector3.new(1.5, 2.5, 1.5),
        Color = Color3.fromRGB(150, 50, 200),
        Material = Enum.Material.Neon,
        Transparency = 0.3,
        CanCollide = false,
        Parent = templates,
    })

    -- Gem_Topaze
    local topaze = makePart({
        Name = "Gem_Topaze",
        Size = Vector3.new(1.5, 2.5, 1.5),
        Color = Color3.fromRGB(255, 180, 0),
        Material = Enum.Material.Neon,
        Transparency = 0.3,
        CanCollide = false,
        Parent = templates,
    })

    print("[MapBuilder] 6 templates créés")
end

function MapBuilder:AddGoldParticles(parent, rate, size)
    local particles = Instance.new("ParticleEmitter")
    particles.Color = ColorSequence.new(C.gold)
    particles.Size = NumberSequence.new(size, 0)
    particles.Lifetime = NumberRange.new(0.5, 1.5)
    particles.Rate = rate
    particles.Speed = NumberRange.new(1, 3)
    particles.SpreadAngle = Vector2.new(180, 180)
    particles.Parent = parent
end

-- ═══════════════════════════════════════════
-- ITEM MODELS (outils dans ServerStorage)
-- ═══════════════════════════════════════════
function MapBuilder:CreateItemModels()
    local models = Instance.new("Folder")
    models.Name = "ItemModels"
    models.Parent = ServerStorage

    -- Tool_Batee
    local batee = Instance.new("Tool")
    batee.Name = "Tool_Batee"
    batee.CanBeDropped = false
    batee.Parent = models
    local bateeHandle = Instance.new("Part")
    bateeHandle.Name = "Handle"
    bateeHandle.Size = Vector3.new(2, 0.3, 2)
    bateeHandle.Color = C.wood
    bateeHandle.Material = Enum.Material.Wood
    bateeHandle.Parent = batee

    -- Tool_Tapis
    local tapis = Instance.new("Tool")
    tapis.Name = "Tool_Tapis"
    tapis.CanBeDropped = false
    tapis.Parent = models
    local tapisHandle = Instance.new("Part")
    tapisHandle.Name = "Handle"
    tapisHandle.Size = Vector3.new(3, 0.1, 2)
    tapisHandle.Color = Color3.fromRGB(180, 160, 120)
    tapisHandle.Material = Enum.Material.Fabric
    tapisHandle.Parent = tapis

    -- Tool_Pioche
    local pioche = Instance.new("Tool")
    pioche.Name = "Tool_Pioche"
    pioche.CanBeDropped = false
    pioche.Parent = models
    local piocheHandle = Instance.new("Part")
    piocheHandle.Name = "Handle"
    piocheHandle.Size = Vector3.new(0.5, 0.5, 4)
    piocheHandle.Color = C.woodDark
    piocheHandle.Material = Enum.Material.Wood
    piocheHandle.Parent = pioche

    print("[MapBuilder] 3 outils créés")
end

-- ═══════════════════════════════════════════
-- MONDE (terrain, ville, zones, NPCs)
-- ═══════════════════════════════════════════
function MapBuilder:CreateWorld()
    local worldFolder = Instance.new("Folder")
    worldFolder.Name = "World"
    worldFolder.Parent = Workspace

    -- Sol principal
    local existingGround = Workspace:FindFirstChild("Baseplate")
    if existingGround then
        existingGround.Name = "Ground"
        existingGround.Size = Vector3.new(800, 1, 800)
        existingGround.Position = Vector3.new(0, -0.5, 0)
        existingGround.Color = C.grass
        existingGround.Material = Enum.Material.Grass
        existingGround.Parent = worldFolder
    else
        makePart({
            Name = "Ground",
            Size = Vector3.new(800, 1, 800),
            Position = Vector3.new(0, -0.5, 0),
            Color = C.grass,
            Material = Enum.Material.Grass,
            Parent = worldFolder,
        })
    end

    -- Spawn location
    local spawnLoc = Instance.new("SpawnLocation")
    spawnLoc.Name = "SpawnLocation"
    spawnLoc.Size = Vector3.new(8, 1, 8)
    spawnLoc.Position = Vector3.new(0, 0.5, 0)
    spawnLoc.Anchored = true
    spawnLoc.Transparency = 1
    spawnLoc.CanCollide = false
    spawnLoc.Parent = worldFolder

    -- Chemin hub → Zone 1 (sud)
    makePart({
        Name = "PathToZone1",
        Size = Vector3.new(10, 0.1, 200),
        Position = Vector3.new(0, 0.05, -100),
        Color = C.dirt,
        Material = Enum.Material.Ground,
        Parent = worldFolder,
    })

    -- Chemin hub → Zone 2 (ouest)
    makePart({
        Name = "PathToZone2",
        Size = Vector3.new(200, 0.1, 10),
        Position = Vector3.new(-100, 0.05, 0),
        Color = C.dirt,
        Material = Enum.Material.Ground,
        Parent = worldFolder,
    })

    -- Chemin hub → Zone 3 (nord)
    makePart({
        Name = "PathToZone3",
        Size = Vector3.new(10, 0.1, 200),
        Position = Vector3.new(0, 0.05, 100),
        Color = C.dirt,
        Material = Enum.Material.Ground,
        Parent = worldFolder,
    })

    self:CreateTown(worldFolder)
    self:CreateZone1(worldFolder)
    self:CreateZone2(worldFolder)
    self:CreateZone3(worldFolder)
end

-- ═══════════════════════════════════════════
-- VILLE (HUB CENTRAL à 0,0,0)
-- ═══════════════════════════════════════════
function MapBuilder:CreateTown(worldFolder)
    local townFolder = Instance.new("Folder")
    townFolder.Name = "Town"
    townFolder.Parent = worldFolder

    local TC = Vector3.new(0, 0, 0) -- Town Center

    -- Place centrale (plancher bois)
    makePart({
        Name = "TownSquare",
        Size = Vector3.new(50, 0.3, 50),
        Position = TC + Vector3.new(0, 0.15, 0),
        Color = C.wood,
        Material = Enum.Material.Wood,
        Parent = townFolder,
    })

    -- Panneau de bienvenue
    local welcomeSign = makePart({
        Name = "WelcomeSign",
        Size = Vector3.new(10, 3, 0.5),
        Position = TC + Vector3.new(0, 5, 24),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = townFolder,
    })
    addBillboard(welcomeSign, "GOLD RUSH LEGACY", C.gold, Vector3.new(0, 2, 0))

    -- Poteau du panneau
    makePart({
        Name = "WelcomePost",
        Size = Vector3.new(0.5, 6, 0.5),
        Position = TC + Vector3.new(0, 3, 24),
        Color = C.woodDark,
        Material = Enum.Material.Wood,
        Parent = townFolder,
    })

    -- ── MAGASIN D'OUTILS (Jake) ──
    self:CreateToolShop(townFolder, TC + Vector3.new(-18, 0, -10))

    -- ── MARCHAND D'OR (Marcel) ──
    self:CreateMerchant(townFolder, TC + Vector3.new(18, 0, -10))

    -- Lampadaires
    for _, offset in ipairs({
        Vector3.new(-22, 0, 22),
        Vector3.new(22, 0, 22),
        Vector3.new(-22, 0, -22),
        Vector3.new(22, 0, -22),
    }) do
        makePart({
            Name = "LampPost",
            Size = Vector3.new(0.5, 10, 0.5),
            Position = TC + offset + Vector3.new(0, 5, 0),
            Color = C.stoneDark,
            Material = Enum.Material.Metal,
            Parent = townFolder,
        })
        makePart({
            Name = "LampLight",
            Size = Vector3.new(2, 1, 2),
            Position = TC + offset + Vector3.new(0, 10.5, 0),
            Color = Color3.fromRGB(255, 230, 150),
            Material = Enum.Material.Neon,
            Parent = townFolder,
        })
    end

    -- Panneaux directionnels
    self:CreateDirectionSign(townFolder, TC + Vector3.new(0, 0, -24),
        "→ Zone 1: Rivière (Sud)", Color3.fromRGB(100, 200, 255))
    self:CreateDirectionSign(townFolder, TC + Vector3.new(-24, 0, 0),
        "→ Zone 2: Collines (Ouest)", Color3.fromRGB(200, 180, 100))
    self:CreateDirectionSign(townFolder, TC + Vector3.new(0, 0, 24),
        "→ Zone 3: Mine (Nord)", Color3.fromRGB(200, 100, 100))
end

function MapBuilder:CreateDirectionSign(parent, position, text, color)
    local post = makePart({
        Name = "SignPost",
        Size = Vector3.new(0.3, 4, 0.3),
        Position = position + Vector3.new(0, 2, 0),
        Color = C.woodDark,
        Material = Enum.Material.Wood,
        Parent = parent,
    })
    local board = makePart({
        Name = "SignBoard",
        Size = Vector3.new(8, 2, 0.3),
        Position = position + Vector3.new(0, 4.5, 0),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = parent,
    })
    addBillboard(board, text, color, Vector3.new(0, 1.5, 0))
end

-- ═══════════════════════════════════════════
-- TOOL SHOP (Jake le Forgeron)
-- ═══════════════════════════════════════════
function MapBuilder:CreateToolShop(parent, pos)
    local shopFolder = Instance.new("Folder")
    shopFolder.Name = "ToolShop"
    shopFolder.Parent = parent

    local SW, SD, SH = 14, 10, 8

    -- Sol
    makePart({
        Name = "ShopFloor",
        Size = Vector3.new(SW, 0.5, SD),
        Position = pos + Vector3.new(0, 0.25, 0),
        Color = C.wood,
        Material = Enum.Material.Wood,
        Parent = shopFolder,
    })

    -- Murs
    makeWall("WallBack", Vector3.new(SW, SH, 0.5), pos + Vector3.new(0, SH/2, -SD/2), C.woodDark, shopFolder)
    makeWall("WallLeft", Vector3.new(0.5, SH, SD), pos + Vector3.new(-SW/2, SH/2, 0), C.woodDark, shopFolder)
    makeWall("WallRight", Vector3.new(0.5, SH, SD), pos + Vector3.new(SW/2, SH/2, 0), C.woodDark, shopFolder)
    makeWall("FrontLeft", Vector3.new(4, SH, 0.5), pos + Vector3.new(-5, SH/2, SD/2), C.woodDark, shopFolder)
    makeWall("FrontRight", Vector3.new(4, SH, 0.5), pos + Vector3.new(5, SH/2, SD/2), C.woodDark, shopFolder)

    -- Toit
    makePart({
        Name = "Roof",
        Size = Vector3.new(SW + 2, 0.5, SD + 2),
        Position = pos + Vector3.new(0, SH + 0.25, 0),
        Color = C.roof,
        Material = Enum.Material.Wood,
        Parent = shopFolder,
    })

    -- Enseigne
    local shopSign = makePart({
        Name = "ShopSign",
        Size = Vector3.new(10, 2.5, 0.5),
        Position = pos + Vector3.new(0, SH + 2, SD/2 + 1),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = shopFolder,
    })
    addBillboard(shopSign, "OUTILS & ÉQUIPEMENT", Color3.fromRGB(50, 30, 10), Vector3.new(0, 2, 0))

    -- Comptoir
    makePart({
        Name = "Counter",
        Size = Vector3.new(10, 3, 2),
        Position = pos + Vector3.new(0, 1.75, -2),
        Color = C.woodDark,
        Material = Enum.Material.Wood,
        Parent = shopFolder,
    })

    -- NPC Jake
    self:CreateNPC(shopFolder, pos + Vector3.new(0, 0.5, -3),
        "ToolVendor", "Jake le Forgeron",
        Color3.fromRGB(139, 90, 43),
        "ToolShop", "Acheter des outils")
end

-- ═══════════════════════════════════════════
-- MARCHAND D'OR (Marcel le Marchand)
-- ═══════════════════════════════════════════
function MapBuilder:CreateMerchant(parent, pos)
    local merchFolder = Instance.new("Folder")
    merchFolder.Name = "GoldMerchant"
    merchFolder.Parent = parent

    -- Comptoir
    makePart({
        Name = "Counter",
        Size = Vector3.new(10, 3, 2),
        Position = pos + Vector3.new(0, 1.5, 0),
        Color = C.woodDark,
        Material = Enum.Material.Wood,
        Parent = merchFolder,
    })

    -- Auvent
    makePart({
        Name = "Awning",
        Size = Vector3.new(14, 0.3, 8),
        Position = pos + Vector3.new(0, 7, -1),
        Color = C.tent,
        Material = Enum.Material.Fabric,
        Parent = merchFolder,
    })

    -- Poteaux
    for _, xOff in ipairs({-6, 6}) do
        makePart({
            Name = "Pole",
            Size = Vector3.new(0.5, 7, 0.5),
            Position = pos + Vector3.new(xOff, 3.5, -4),
            Color = C.wood,
            Material = Enum.Material.Wood,
            Parent = merchFolder,
        })
    end

    -- Balance dorée
    makePart({
        Name = "GoldBalance",
        Size = Vector3.new(2, 1.5, 1),
        Position = pos + Vector3.new(-3, 3.7, 0),
        Color = C.gold,
        Material = Enum.Material.Metal,
        Parent = merchFolder,
    })

    -- NPC Marcel
    self:CreateNPC(merchFolder, pos + Vector3.new(0, 0.3, -2),
        "Marcel", "Marcel le Marchand",
        Color3.fromRGB(50, 100, 50),
        "Merchant", "Vendre de l'or")
end

-- ═══════════════════════════════════════════
-- NPC GENERIC
-- ═══════════════════════════════════════════
function MapBuilder:CreateNPC(parent, pos, npcName, displayName, torsoColor, npcType, actionText)
    local npc = Instance.new("Model")
    npc.Name = npcName
    npc.Parent = parent

    local torso = Instance.new("Part")
    torso.Name = "HumanoidRootPart"
    torso.Anchored = true
    torso.Size = Vector3.new(2, 3, 1)
    torso.Position = pos + Vector3.new(0, 2.5, 0)
    torso.Color = torsoColor
    torso.Material = Enum.Material.SmoothPlastic
    torso.Parent = npc

    local head = Instance.new("Part")
    head.Name = "Head"
    head.Anchored = true
    head.Shape = Enum.PartType.Ball
    head.Size = Vector3.new(2, 2, 2)
    head.Position = pos + Vector3.new(0, 4.5, 0)
    head.Color = Color3.fromRGB(200, 160, 110)
    head.Material = Enum.Material.SmoothPlastic
    head.Parent = npc

    -- Chapeau
    local hat = Instance.new("Part")
    hat.Name = "Hat"
    hat.Anchored = true
    hat.Size = Vector3.new(2.8, 0.3, 2.8)
    hat.Position = pos + Vector3.new(0, 5.7, 0)
    hat.Color = Color3.fromRGB(100, 65, 25)
    hat.Material = Enum.Material.Leather
    hat.Parent = npc

    -- Jambes
    for i, xOff in ipairs({-0.5, 0.5}) do
        local leg = Instance.new("Part")
        leg.Name = "Leg" .. i
        leg.Anchored = true
        leg.Size = Vector3.new(0.8, 2, 0.8)
        leg.Position = pos + Vector3.new(xOff, 1, 0)
        leg.Color = Color3.fromRGB(70, 50, 30)
        leg.Material = Enum.Material.SmoothPlastic
        leg.Parent = npc
    end

    npc.PrimaryPart = torso
    addBillboard(head, displayName, C.gold, Vector3.new(0, 3, 0))

    -- ProximityPrompt
    local prompt = Instance.new("ProximityPrompt")
    prompt.ObjectText = displayName
    prompt.ActionText = actionText
    prompt.HoldDuration = 0
    prompt.MaxActivationDistance = 10
    prompt.KeyboardKeyCode = Enum.KeyCode.E
    prompt.RequiresLineOfSight = false
    prompt.Parent = torso

    torso:SetAttribute("NPCType", npcType)
    torso:SetAttribute("NPCName", displayName)
end

-- ═══════════════════════════════════════════
-- ZONE 1 — RIVIÈRE TRANQUILLE (Sud, z=-200)
-- ═══════════════════════════════════════════
function MapBuilder:CreateZone1(worldFolder)
    local z1 = Instance.new("Folder")
    z1.Name = "Zone1_Riviere"
    z1.Parent = worldFolder

    local center = ZoneConfig.Zones.Zone1.WorldPosition -- (0, 0, -200)

    -- Panneau de zone
    local sign = makePart({
        Name = "ZoneSign",
        Size = Vector3.new(10, 3, 0.5),
        Position = center + Vector3.new(0, 5, 50),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = z1,
    })
    addBillboard(sign, "Zone 1 — Rivière Tranquille", Color3.fromRGB(100, 200, 255), Vector3.new(0, 2, 0))

    -- Eau de rivière
    for i = 1, 6 do
        local zOff = (i - 3.5) * 20
        local xWobble = math.sin(i * 0.8) * 8
        makePart({
            Name = "Water_" .. i,
            Size = Vector3.new(18, 0.8, 22),
            Position = center + Vector3.new(xWobble, -0.4, zOff),
            Color = C.water,
            Material = Enum.Material.Glass,
            Transparency = 0.3,
            Parent = z1,
        })
    end

    -- Berges (sable)
    for i = 1, 6 do
        local zOff = (i - 3.5) * 20
        local xWobble = math.sin(i * 0.8) * 8
        makePart({
            Name = "BankLeft_" .. i,
            Size = Vector3.new(8, 0.4, 22),
            Position = center + Vector3.new(-12 + xWobble, -0.2, zOff),
            Color = C.sand,
            Material = Enum.Material.Sand,
            Parent = z1,
        })
        makePart({
            Name = "BankRight_" .. i,
            Size = Vector3.new(8, 0.4, 22),
            Position = center + Vector3.new(12 + xWobble, -0.2, zOff),
            Color = C.sand,
            Material = Enum.Material.Sand,
            Parent = z1,
        })
    end

    -- Rochers
    for i = 1, 5 do
        makePart({
            Name = "Rock_" .. i,
            Size = Vector3.new(
                math.random(2, 5), math.random(1, 3), math.random(2, 5)
            ),
            Position = center + Vector3.new(
                math.random(-8, 8), math.random(0, 1), math.random(-40, 40)
            ),
            Color = C.stoneDark,
            Material = Enum.Material.Slate,
            Parent = z1,
        })
    end
end

-- ═══════════════════════════════════════════
-- ZONE 2 — COLLINES AMBRÉES (Ouest, x=-200)
-- ═══════════════════════════════════════════
function MapBuilder:CreateZone2(worldFolder)
    local z2 = Instance.new("Folder")
    z2.Name = "Zone2_Collines"
    z2.Parent = worldFolder

    local center = ZoneConfig.Zones.Zone2.WorldPosition -- (-200, 0, 0)

    -- Terrain surélevé
    makePart({
        Name = "Ground",
        Size = Vector3.new(120, 2, 120),
        Position = center + Vector3.new(0, 1, 0),
        Color = Color3.fromRGB(100, 80, 45),
        Material = Enum.Material.Ground,
        Parent = z2,
    })

    -- Panneau
    local sign = makePart({
        Name = "ZoneSign",
        Size = Vector3.new(10, 3, 0.5),
        Position = center + Vector3.new(60, 5, 0),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = z2,
    })
    addBillboard(sign, "Zone 2 — Collines Ambrées [Niv.2]",
        Color3.fromRGB(200, 180, 100), Vector3.new(0, 2, 0))

    -- Collines
    for i = 1, 5 do
        local hillSize = Vector3.new(
            25 + math.random(0, 15), 8 + math.random(0, 10), 25 + math.random(0, 15)
        )
        makePart({
            Name = "Hill_" .. i,
            Size = hillSize,
            Position = center + Vector3.new(
                math.random(-40, 40), hillSize.Y / 2 + 2, math.random(-40, 40)
            ),
            Color = Color3.fromRGB(140 + math.random(-20, 20), 100 + math.random(-20, 20), 50),
            Material = Enum.Material.Rock,
            Parent = z2,
        })
    end
end

-- ═══════════════════════════════════════════
-- ZONE 3 — MINE DE CROW CREEK (Nord, z=200)
-- ═══════════════════════════════════════════
function MapBuilder:CreateZone3(worldFolder)
    local z3 = Instance.new("Folder")
    z3.Name = "Zone3_Mine"
    z3.Parent = worldFolder

    local center = ZoneConfig.Zones.Zone3.WorldPosition -- (0, 0, 200)

    -- Entrée de la mine
    makePart({
        Name = "MineEntrance",
        Size = Vector3.new(15, 12, 3),
        Position = center + Vector3.new(0, 6, -40),
        Color = C.stoneDark,
        Material = Enum.Material.Slate,
        Parent = z3,
    })
    makePart({
        Name = "MineArch",
        Size = Vector3.new(8, 2, 3),
        Position = center + Vector3.new(0, 11, -40),
        Color = C.stone,
        Material = Enum.Material.Slate,
        Parent = z3,
    })

    -- Panneau
    local sign = makePart({
        Name = "ZoneSign",
        Size = Vector3.new(10, 3, 0.5),
        Position = center + Vector3.new(0, 5, -50),
        Color = C.sign,
        Material = Enum.Material.Wood,
        Parent = z3,
    })
    addBillboard(sign, "Zone 3 — Mine de Crow Creek [Niv.3]",
        Color3.fromRGB(200, 100, 100), Vector3.new(0, 2, 0))

    -- Sol intérieur mine
    makePart({
        Name = "MineFloor",
        Size = Vector3.new(100, 1, 100),
        Position = center + Vector3.new(0, -0.5, 0),
        Color = Color3.fromRGB(60, 55, 50),
        Material = Enum.Material.Slate,
        Parent = z3,
    })

    -- Rails décoratifs
    for i = 1, 3 do
        makePart({
            Name = "Rail_" .. i,
            Size = Vector3.new(80, 0.2, 0.5),
            Position = center + Vector3.new(0, 0.1, -20 + i * 15),
            Color = C.stoneDark,
            Material = Enum.Material.Metal,
            Parent = z3,
        })
    end

    -- Cristaux décoratifs
    for i = 1, 6 do
        makePart({
            Name = "Crystal_" .. i,
            Size = Vector3.new(1, math.random(3, 7), 1),
            Position = center + Vector3.new(
                math.random(-35, 35), math.random(1, 3), math.random(-30, 30)
            ),
            Color = Color3.fromRGB(
                math.random(100, 200), math.random(50, 150), math.random(150, 255)
            ),
            Material = Enum.Material.Neon,
            Transparency = 0.3,
            Parent = z3,
        })
    end
end

return MapBuilder
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="26">
        <Properties>
          <string name="Name">MiningSystem</string>
          <string name="Source"><![CDATA[--[[
    MiningSystem.lua (ModuleScript)
    ROLE : Gere la logique de minage cote serveur.
           Recoit les requetes du client, valide, calcule les drops, distribue.
]]

local MiningSystem = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local ServerStorage = game:GetService("ServerStorage")

local DataManager = require(ServerScriptService.Core.DataManager)
local EconomyConfig = require(ReplicatedStorage.Modules.Config.EconomyConfig)
local ToolConfig = require(ReplicatedStorage.Modules.Config.ToolConfig)

-- Cooldowns anti-spam
local MiningCooldowns = {} -- { [userId] = lastMineTime }
local MIN_MINE_INTERVAL = 1

-- ==========================================
-- INIT
-- ==========================================
function MiningSystem:Init()
    local events = ReplicatedStorage.Events.RemoteEvents

    events.RequestMine.OnServerEvent:Connect(function(player, depositId)
        self:HandleMineRequest(player, depositId)
    end)

    events.BateeMinigameResult.OnServerEvent:Connect(function(player, depositId, score)
        self:HandleBateeResult(player, depositId, score)
    end)

    print("[MiningSystem] Initialisé ✓")
end

-- ==========================================
-- TRAITER UNE REQUÊTE DE MINAGE
-- ==========================================
function MiningSystem:HandleMineRequest(player: Player, depositId: string)
    -- Anti-spam
    local now = os.clock()
    if MiningCooldowns[player.UserId] and (now - MiningCooldowns[player.UserId]) < MIN_MINE_INTERVAL then
        return
    end
    MiningCooldowns[player.UserId] = now

    -- Trouver le gisement
    local deposit = game.Workspace.ActiveGoldDeposits:FindFirstChild(depositId)
    if not deposit then return end
    if not deposit:GetAttribute("IsActive") then return end

    -- Vérifier la distance (anti-exploit)
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local distance = (character.HumanoidRootPart.Position - self:GetDepositPosition(deposit)).Magnitude
    if distance > 15 then
        warn("[MiningSystem] Distance exploit détecté :", player.Name, distance)
        return
    end

    -- Vérifier la zone et le niveau requis
    local zoneId = deposit:GetAttribute("ZoneId")
    local data = DataManager:GetData(player)
    if not data then return end

    local ZoneConfig = require(ReplicatedStorage.Modules.Config.ZoneConfig)
    local zoneData = ZoneConfig.Zones[zoneId]
    if data.Level < zoneData.RequiredLevel then
        ReplicatedStorage.Events.RemoteEvents.MineResult:FireClient(
            player, false, "Niveau insuffisant pour cette zone !"
        )
        return
    end

    -- Vérifier que le joueur a un outil adapté
    local hasTool = self:HasValidTool(player, zoneId)
    if not hasTool then
        ReplicatedStorage.Events.RemoteEvents.MineResult:FireClient(
            player, false, "Tu n'as pas l'outil requis !"
        )
        return
    end

    -- Zone 1 : déclencher le mini-jeu de batée côté client
    if zoneId == "Zone1" then
        deposit:SetAttribute("IsActive", false)
        ReplicatedStorage.Events.RemoteEvents.StartBateeMinigame:FireClient(player, depositId)
        return
    end

    -- Zones 2 et 3 : minage direct
    self:ProcessMining(player, deposit, zoneId, 1.0)
end

-- ==========================================
-- RÉSULTAT DU MINI-JEU DE BATÉE
-- ==========================================
function MiningSystem:HandleBateeResult(player: Player, depositId: string, score: number)
    if type(score) ~= "number" then return end
    score = math.clamp(score, 0, 1)

    local deposit = game.Workspace.ActiveGoldDeposits:FindFirstChild(depositId)
    if not deposit then return end

    local zoneId = deposit:GetAttribute("ZoneId")
    self:ProcessMining(player, deposit, zoneId, score)
end

-- ==========================================
-- TRAITEMENT DU MINAGE (calcul des drops)
-- ==========================================
function MiningSystem:ProcessMining(player: Player, deposit: Instance, zoneId: string, score: number)
    local data = DataManager:GetData(player)
    if not data then return end

    -- Déterminer la table de drops
    local dropTable = self:GetDropTable(zoneId, deposit)
    if not dropTable then return end

    -- Déterminer le bonus d'outil
    local toolLevel = self:GetBestToolLevel(player, zoneId)
    local qtyMultiplier = EconomyConfig.ToolBonuses.QuantityMultiplier[toolLevel] or 1.0

    -- Vérifier buff Saloon
    if data.Saloon.BuffActive == "LuckBoost" and os.time() < data.Saloon.BuffExpiry then
        qtyMultiplier = qtyMultiplier * 1.15
    end

    -- Appliquer le score du mini-jeu
    qtyMultiplier = qtyMultiplier * math.max(0.3, score)

    -- Calculer les drops
    local drops = {}
    for itemName, dropData in pairs(dropTable) do
        local roll = math.random(1, 100)
        if roll <= dropData.Chance then
            local baseQty = math.random(dropData.MinQty, dropData.MaxQty)
            local finalQty = math.max(1, math.floor(baseQty * qtyMultiplier))
            drops[itemName] = finalQty

            DataManager:AddToInventory(player, itemName, finalQty)

            local xpKey = "Mine" .. itemName
            local xp = EconomyConfig.XPRewards[xpKey] or 5
            DataManager:AddXP(player, xp)
        end
    end

    -- Si aucun drop, donner au moins 1 paillette
    if next(drops) == nil then
        drops["Paillettes"] = 1
        DataManager:AddToInventory(player, "Paillettes", 1)
        DataManager:AddXP(player, EconomyConfig.XPRewards.MinePaillette or 5)
    end

    -- Notifier le QuestManager
    local QuestManager = require(ServerScriptService.Systems.QuestManager)
    for itemName, qty in pairs(drops) do
        QuestManager:OnMineGold(player, itemName, qty)
    end

    -- Envoyer le résultat au client
    ReplicatedStorage.Events.RemoteEvents.MineResult:FireClient(player, true, drops)

    -- Mettre à jour les données client
    local updatedData = DataManager:GetData(player)
    if updatedData then
        local updateEvent = ReplicatedStorage.Events.RemoteEvents:FindFirstChild("PlayerDataUpdated")
        if updateEvent then
            updateEvent:FireClient(player, updatedData)
        end
    end

    -- Détruire le gisement
    local GoldSpawner = require(ServerScriptService.Systems.GoldSpawner)
    GoldSpawner:DestroyDeposit(deposit)
end

-- ==========================================
-- HELPERS
-- ==========================================
function MiningSystem:GetDropTable(zoneId: string, deposit: Instance)
    if zoneId == "Zone1" then
        return EconomyConfig.DropRates.Zone1
    elseif zoneId == "Zone2" then
        if deposit.Name:match("Filon") then
            return EconomyConfig.DropRates.Zone2_Filon
        end
        return EconomyConfig.DropRates.Zone2_Detecteur
    elseif zoneId == "Zone3" then
        return EconomyConfig.DropRates.Zone3
    end
    return nil
end

function MiningSystem:HasValidTool(player: Player, zoneId: string): boolean
    local data = DataManager:GetData(player)
    if not data then return false end

    local ZoneConfig = require(ReplicatedStorage.Modules.Config.ZoneConfig)
    local zoneData = ZoneConfig.Zones[zoneId]

    for _, toolName in ipairs(zoneData.AllowedTools) do
        if data.Tools[toolName] and data.Tools[toolName].Owned then
            return true
        end
    end
    return false
end

function MiningSystem:GetBestToolLevel(player: Player, zoneId: string): number
    local data = DataManager:GetData(player)
    if not data then return 1 end

    local ZoneConfig = require(ReplicatedStorage.Modules.Config.ZoneConfig)
    local zoneData = ZoneConfig.Zones[zoneId]
    local bestLevel = 1

    for _, toolName in ipairs(zoneData.AllowedTools) do
        if data.Tools[toolName] and data.Tools[toolName].Owned then
            bestLevel = math.max(bestLevel, data.Tools[toolName].Level)
        end
    end
    return bestLevel
end

function MiningSystem:GetDepositPosition(deposit: Instance): Vector3
    if deposit:IsA("Model") and deposit.PrimaryPart then
        return deposit.PrimaryPart.Position
    elseif deposit:IsA("BasePart") then
        return deposit.Position
    end
    return Vector3.zero
end

function MiningSystem:EquipOwnedTools(player: Player)
    local data = DataManager:GetData(player)
    if not data then return end

    for toolName, toolData in pairs(data.Tools) do
        if toolData.Owned then
            self:GiveTool(player, toolName)
        end
    end
end

function MiningSystem:GiveTool(player: Player, toolName: string)
    local template = ServerStorage.ItemModels:FindFirstChild("Tool_" .. toolName)
    if template then
        -- Ne pas donner en doublon
        if player.Backpack:FindFirstChild(toolName) then return end
        local character = player.Character
        if character and character:FindFirstChild(toolName) then return end

        local tool = template:Clone()
        tool.Name = toolName
        tool.Parent = player.Backpack
    end
end

return MiningSystem
]]></string>
        </Properties>
      </Item>
