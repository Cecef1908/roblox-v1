        <Item class="LocalScript" referent="35">
          <Properties>
            <string name="Name">MiningClient</string>
            <string name="Source"><![CDATA[--[[
    MiningClient.client.lua (LocalScript)
    ROLE : Gère les interactions de minage côté client.
           Détecte les ProximityPrompt, envoie les requêtes au serveur,
           affiche les résultats (particules, sons, notifications).
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("RemoteEvents")

-- Charger le UIManager
local UIManager = require(script.Parent.UIManager)
UIManager:Init()

-- ==========================================
-- ÉCOUTER LES ProximityPrompts SUR LES GISEMENTS
-- ==========================================
local ActiveGoldDeposits = workspace:WaitForChild("ActiveGoldDeposits")

local function ConnectPrompt(prompt)
    prompt.Triggered:Connect(function()
        local deposit = prompt.Parent
        Events.RequestMine:FireServer(deposit.Name)
    end)
end

-- Écouter les nouveaux gisements
ActiveGoldDeposits.DescendantAdded:Connect(function(descendant)
    if descendant:IsA("ProximityPrompt") then
        ConnectPrompt(descendant)
    end
end)

-- Connecter les prompts déjà présents
for _, deposit in ActiveGoldDeposits:GetChildren() do
    local prompt = deposit:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        ConnectPrompt(prompt)
    end
end

-- ==========================================
-- RÉSULTAT DE MINAGE
-- ==========================================
Events.MineResult.OnClientEvent:Connect(function(success, data)
    if success then
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local pos = character.HumanoidRootPart.Position

            local offsetY = 0
            for itemName, qty in pairs(data) do
                UIManager:ShowFloatingText(
                    pos + Vector3.new(0, 3 + offsetY, 0),
                    string.format("+%d %s", qty, itemName),
                    Color3.fromRGB(255, 215, 0)
                )
                offsetY = offsetY + 1.5
            end

            UIManager:PlayMineEffect(pos)
            UIManager:PlaySound("MineSuccess")
        end

        UIManager:RefreshHUD()
    else
        UIManager:ShowNotification(tostring(data), "Error")
    end
end)

print("[MiningClient] Initialisé ✓")
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="36">
          <Properties>
            <string name="Name">UIManager</string>
            <string name="Source"><![CDATA[--[[
    UIManager.lua (ModuleScript)
    ROLE : Module partage pour l'UI client.
    Gere le HUD, notifications, textes flottants, effets visuels et sons.
]]

local UIManager = {}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("RemoteEvents")

-- État joueur local
local PlayerData = nil

-- ==========================================
-- INIT — appelé par MiningClient ou autre
-- ==========================================
function UIManager:Init()
    -- Écouter les données initiales du serveur
    Events.InitPlayerData.OnClientEvent:Connect(function(data)
        PlayerData = data
        self:RefreshHUD()
        print("[UIManager] Données initiales reçues")
    end)

    -- Écouter les mises à jour
    Events.PlayerDataUpdated.OnClientEvent:Connect(function(data)
        PlayerData = data
        self:RefreshHUD()
    end)

    -- Écouter les notifications du serveur
    local notifyEvent = Events:FindFirstChild("NotifyPlayer")
    if notifyEvent then
        notifyEvent.OnClientEvent:Connect(function(message, notifType)
            self:ShowNotification(message, notifType or "Info")
        end)
    end

    -- Écouter les level up
    Events.LevelUp.OnClientEvent:Connect(function(level, levelName)
        self:ShowNotification("LEVEL UP ! Niveau " .. level .. " — " .. levelName, "LevelUp")
    end)

    -- Créer le HUD
    self:CreateHUD()

    print("[UIManager] Initialisé ✓")
end

-- ==========================================
-- HUD PRINCIPAL
-- ==========================================
function UIManager:CreateHUD()
    local mainHUD = playerGui:FindFirstChild("MainHUD")
    if not mainHUD then
        mainHUD = Instance.new("ScreenGui")
        mainHUD.Name = "MainHUD"
        mainHUD.ResetOnSpawn = false
        mainHUD.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        mainHUD.Parent = playerGui
    end

    -- Cash display (top right)
    local cashFrame = mainHUD:FindFirstChild("CashFrame")
    if not cashFrame then
        cashFrame = Instance.new("Frame")
        cashFrame.Name = "CashFrame"
        cashFrame.Size = UDim2.new(0, 200, 0, 40)
        cashFrame.Position = UDim2.new(1, -210, 0, 10)
        cashFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        cashFrame.BackgroundTransparency = 0.3
        cashFrame.Parent = mainHUD

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = cashFrame

        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(255, 215, 0)
        stroke.Thickness = 1
        stroke.Parent = cashFrame

        local cashLabel = Instance.new("TextLabel")
        cashLabel.Name = "CashLabel"
        cashLabel.Size = UDim2.new(1, -10, 1, 0)
        cashLabel.Position = UDim2.new(0, 10, 0, 0)
        cashLabel.BackgroundTransparency = 1
        cashLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        cashLabel.Font = Enum.Font.GothamBold
        cashLabel.TextSize = 18
        cashLabel.TextXAlignment = Enum.TextXAlignment.Right
        cashLabel.Text = "$ 50"
        cashLabel.Parent = cashFrame
    end

    -- Level + XP display (top right, below cash)
    local levelFrame = mainHUD:FindFirstChild("LevelFrame")
    if not levelFrame then
        levelFrame = Instance.new("Frame")
        levelFrame.Name = "LevelFrame"
        levelFrame.Size = UDim2.new(0, 200, 0, 30)
        levelFrame.Position = UDim2.new(1, -210, 0, 55)
        levelFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        levelFrame.BackgroundTransparency = 0.3
        levelFrame.Parent = mainHUD

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = levelFrame

        local levelLabel = Instance.new("TextLabel")
        levelLabel.Name = "LevelLabel"
        levelLabel.Size = UDim2.new(1, -10, 1, 0)
        levelLabel.Position = UDim2.new(0, 10, 0, 0)
        levelLabel.BackgroundTransparency = 1
        levelLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
        levelLabel.Font = Enum.Font.Gotham
        levelLabel.TextSize = 14
        levelLabel.TextXAlignment = Enum.TextXAlignment.Right
        levelLabel.Text = "Niv.1 | XP: 0"
        levelLabel.Parent = levelFrame
    end

    -- Inventory display (left side)
    local invFrame = mainHUD:FindFirstChild("InventoryFrame")
    if not invFrame then
        invFrame = Instance.new("Frame")
        invFrame.Name = "InventoryFrame"
        invFrame.Size = UDim2.new(0, 200, 0, 260)
        invFrame.Position = UDim2.new(0, 10, 0.5, -130)
        invFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        invFrame.BackgroundTransparency = 0.15
        invFrame.Parent = mainHUD

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = invFrame

        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(255, 215, 0)
        stroke.Thickness = 1
        stroke.Transparency = 0.5
        stroke.Parent = invFrame

        local title = Instance.new("TextLabel")
        title.Name = "Title"
        title.Size = UDim2.new(1, 0, 0, 25)
        title.BackgroundTransparency = 1
        title.TextColor3 = Color3.fromRGB(255, 215, 0)
        title.Font = Enum.Font.GothamBold
        title.TextSize = 14
        title.Text = "INVENTAIRE"
        title.Parent = invFrame

        local listFrame = Instance.new("Frame")
        listFrame.Name = "ItemList"
        listFrame.Size = UDim2.new(1, -10, 1, -30)
        listFrame.Position = UDim2.new(0, 5, 0, 28)
        listFrame.BackgroundTransparency = 1
        listFrame.Parent = invFrame

        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 2)
        layout.Parent = listFrame
    end
end

-- ==========================================
-- REFRESH HUD
-- ==========================================
function UIManager:RefreshHUD()
    if not PlayerData then return end

    local mainHUD = playerGui:FindFirstChild("MainHUD")
    if not mainHUD then return end

    -- Cash
    local cashLabel = mainHUD.CashFrame:FindFirstChild("CashLabel")
    if cashLabel then
        cashLabel.Text = "$ " .. tostring(PlayerData.Cash or 0)
    end

    -- Level + XP
    local levelLabel = mainHUD.LevelFrame:FindFirstChild("LevelLabel")
    if levelLabel then
        levelLabel.Text = string.format("Niv.%d | XP: %d", PlayerData.Level or 1, PlayerData.XP or 0)
    end

    -- Inventory
    local itemList = mainHUD.InventoryFrame:FindFirstChild("ItemList")
    if itemList and PlayerData.Inventory then
        -- Clear existing
        for _, child in itemList:GetChildren() do
            if child:IsA("TextLabel") then child:Destroy() end
        end

        local displayNames = {
            Paillettes = "Paillettes",
            OrPur = "Or Pur",
            Lingots = "Lingots",
            Pepites = "Pépites",
            MineraiOr = "Minerai d'Or",
            Quartz = "Quartz",
            Amethyste = "Améthyste",
            Topaze = "Topaze",
        }

        local order = {"Paillettes", "Pepites", "OrPur", "MineraiOr", "Lingots", "Quartz", "Amethyste", "Topaze"}
        for i, key in ipairs(order) do
            local qty = PlayerData.Inventory[key] or 0
            if qty > 0 then
                local label = Instance.new("TextLabel")
                label.Name = key
                label.Size = UDim2.new(1, 0, 0, 22)
                label.BackgroundTransparency = 1
                label.TextColor3 = Color3.fromRGB(220, 220, 220)
                label.Font = Enum.Font.Gotham
                label.TextSize = 13
                label.TextXAlignment = Enum.TextXAlignment.Left
                label.Text = string.format("  %s: %d", displayNames[key] or key, qty)
                label.LayoutOrder = i
                label.Parent = itemList
            end
        end
    end
end

-- ==========================================
-- TEXTE FLOTTANT (drops)
-- ==========================================
function UIManager:ShowFloatingText(worldPos: Vector3, text: string, color: Color3)
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Size = UDim2.new(0, 200, 0, 50)
    billboardGui.StudsOffset = Vector3.new(0, 2, 0)
    billboardGui.Adornee = nil
    billboardGui.AlwaysOnTop = true
    billboardGui.Parent = playerGui

    -- Create anchor part
    local anchor = Instance.new("Part")
    anchor.Size = Vector3.new(0.1, 0.1, 0.1)
    anchor.Position = worldPos
    anchor.Anchored = true
    anchor.CanCollide = false
    anchor.Transparency = 1
    anchor.Parent = workspace

    billboardGui.Adornee = anchor

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color or Color3.fromRGB(255, 215, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 20
    label.TextStrokeTransparency = 0.5
    label.Text = text
    label.Parent = billboardGui

    -- Animate upward + fade
    task.spawn(function()
        for i = 1, 30 do
            anchor.Position = anchor.Position + Vector3.new(0, 0.05, 0)
            label.TextTransparency = i / 30
            label.TextStrokeTransparency = 0.5 + (i / 30) * 0.5
            task.wait(0.03)
        end
        billboardGui:Destroy()
        anchor:Destroy()
    end)
end

-- ==========================================
-- NOTIFICATION
-- ==========================================
function UIManager:ShowNotification(message: string, notifType: string)
    local colors = {
        Info = Color3.fromRGB(100, 180, 255),
        Error = Color3.fromRGB(255, 80, 80),
        Success = Color3.fromRGB(80, 255, 80),
        LevelUp = Color3.fromRGB(180, 100, 255),
    }

    local mainHUD = playerGui:FindFirstChild("MainHUD")
    if not mainHUD then return end

    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 400, 0, 40)
    notif.Position = UDim2.new(0.5, -200, 0, 120)
    notif.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    notif.BackgroundTransparency = 0.2
    notif.TextColor3 = colors[notifType] or colors.Info
    notif.Font = Enum.Font.GothamBold
    notif.TextSize = 16
    notif.Text = message
    notif.Parent = mainHUD

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = notif

    -- Fade out after 3 seconds
    task.spawn(function()
        task.wait(3)
        for i = 1, 20 do
            notif.BackgroundTransparency = 0.2 + (i / 20) * 0.8
            notif.TextTransparency = i / 20
            task.wait(0.02)
        end
        notif:Destroy()
    end)
end

-- ==========================================
-- EFFETS
-- ==========================================
function UIManager:PlayMineEffect(position: Vector3)
    -- Particules dorées à la position du minage
    local part = Instance.new("Part")
    part.Size = Vector3.new(1, 1, 1)
    part.Position = position
    part.Anchored = true
    part.CanCollide = false
    part.Transparency = 1
    part.Parent = workspace

    local emitter = Instance.new("ParticleEmitter")
    emitter.Color = ColorSequence.new(Color3.fromRGB(255, 215, 0))
    emitter.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.5),
        NumberSequenceKeypoint.new(1, 0),
    })
    emitter.Lifetime = NumberRange.new(0.5, 1)
    emitter.Speed = NumberRange.new(5, 10)
    emitter.SpreadAngle = Vector2.new(360, 360)
    emitter.Rate = 0
    emitter.Parent = part

    emitter:Emit(20)

    task.delay(2, function()
        part:Destroy()
    end)
end

function UIManager:PlaySound(soundName: string)
    -- Simple sound feedback
    local soundIds = {
        MineSuccess = "rbxasset://sounds/impact_explosion_03.mp3",
    }

    local id = soundIds[soundName]
    if id then
        local sound = Instance.new("Sound")
        sound.SoundId = id
        sound.Volume = 0.5
        sound.Parent = player.PlayerGui
        sound:Play()
        sound.Ended:Connect(function()
            sound:Destroy()
        end)
    end
end

-- ==========================================
-- GETTER
-- ==========================================
function UIManager:GetPlayerData()
    return PlayerData
end

return UIManager
]]></string>
