  <Item class="SoundService" referent="29">
    <Properties>
      <string name="Name">SoundService</string>
    </Properties>
  </Item>
  <Item class="StarterGui" referent="30">
    <Properties>
      <string name="Name">StarterGui</string>
    </Properties>
  </Item>
  <Item class="StarterPlayer" referent="31">
    <Properties>
      <string name="Name">StarterPlayer</string>
    </Properties>
    <Item class="StarterPlayerScripts" referent="32">
      <Properties>
        <string name="Name">StarterPlayerScripts</string>
      </Properties>
      <Item class="Folder" referent="33">
        <Properties>
          <string name="Name">Core</string>
        </Properties>
        <Item class="LocalScript" referent="34">
          <Properties>
            <string name="Name">InteractionClient</string>
            <string name="Source"><![CDATA[--[[
    InteractionClient.client.lua (LocalScript)
    ROLE : Gère les interactions avec les NPCs (achat d'outils, vente d'or).
    Crée le UI de shop/vente quand le joueur interagit avec un NPC.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("RemoteEvents")

local UIManager = require(script.Parent.UIManager)

-- ==========================================
-- ÉCOUTER LES NPC ProximityPrompts
-- ==========================================
local function OnPromptTriggered(prompt)
    local part = prompt.Parent
    if not part then return end

    local npcType = part:GetAttribute("NPCType")
    if not npcType then return end

    if npcType == "ToolShop" then
        ShowToolShop()
    elseif npcType == "Merchant" then
        ShowSellMenu()
    end
end

-- Connecter tous les ProximityPrompts dans le monde
workspace.DescendantAdded:Connect(function(descendant)
    if descendant:IsA("ProximityPrompt") then
        local part = descendant.Parent
        if part and part:GetAttribute("NPCType") then
            descendant.Triggered:Connect(function()
                OnPromptTriggered(descendant)
            end)
        end
    end
end)

-- Connecter ceux déjà présents
for _, desc in workspace:GetDescendants() do
    if desc:IsA("ProximityPrompt") then
        local part = desc.Parent
        if part and part:GetAttribute("NPCType") then
            desc.Triggered:Connect(function()
                OnPromptTriggered(desc)
            end)
        end
    end
end

-- ==========================================
-- TOOL SHOP UI
-- ==========================================
function ShowToolShop()
    -- Fermer si déjà ouvert
    local existing = playerGui:FindFirstChild("ShopUI")
    if existing then existing:Destroy() end

    local data = UIManager:GetPlayerData()
    if not data then return end

    local gui = Instance.new("ScreenGui")
    gui.Name = "ShopUI"
    gui.ResetOnSpawn = false
    gui.Parent = playerGui

    -- Background
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 400, 0, 350)
    bg.Position = UDim2.new(0.5, -200, 0.5, -175)
    bg.BackgroundColor3 = Color3.fromRGB(30, 25, 20)
    bg.BackgroundTransparency = 0.1
    bg.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = bg

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 215, 0)
    stroke.Thickness = 2
    stroke.Parent = bg

    -- Title
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 40)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.fromRGB(255, 215, 0)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 20
    title.Text = "Jake le Forgeron — Outils"
    title.Parent = bg

    -- Close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 16
    closeBtn.Text = "X"
    closeBtn.Parent = bg
    local closeBtnCorner = Instance.new("UICorner")
    closeBtnCorner.CornerRadius = UDim.new(0, 6)
    closeBtnCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)

    -- Tool list
    local ToolConfig = require(ReplicatedStorage.Modules.Config.ToolConfig)
    local yOffset = 50

    for toolName, toolData in pairs(ToolConfig.Tools) do
        local owned = data.Tools[toolName] and data.Tools[toolName].Owned
        local level = owned and data.Tools[toolName].Level or 0

        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -20, 0, 55)
        row.Position = UDim2.new(0, 10, 0, yOffset)
        row.BackgroundColor3 = Color3.fromRGB(50, 45, 35)
        row.BackgroundTransparency = 0.3
        row.Parent = bg

        local rowCorner = Instance.new("UICorner")
        rowCorner.CornerRadius = UDim.new(0, 6)
        rowCorner.Parent = row

        -- Tool name + level
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(0.55, 0, 1, 0)
        nameLabel.Position = UDim2.new(0, 10, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 14
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = row

        if owned then
            local levelName = toolData.Levels[level] and toolData.Levels[level].Name or toolData.DisplayName
            nameLabel.Text = levelName .. " (Niv." .. level .. ")"
        else
            nameLabel.Text = toolData.DisplayName
        end

        -- Action button
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 120, 0, 35)
        btn.Position = UDim2.new(1, -130, 0.5, -17)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 13
        btn.Parent = row

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = btn

        if not owned then
            local price = toolData.Levels[1].BuyPrice
            if price and price > 0 then
                btn.Text = "Acheter " .. price .. "$"
                btn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                btn.TextColor3 = Color3.new(1, 1, 1)
                btn.MouseButton1Click:Connect(function()
                    Events.RequestBuyTool:FireServer(toolName)
                    gui:Destroy()
                end)
            else
                btn.Text = "Gratuit"
                btn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        else
            local nextLevel = level + 1
            local nextData = toolData.Levels[nextLevel]
            if nextData then
                btn.Text = "Améliorer " .. nextData.UpgradePrice .. "$"
                btn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
                btn.TextColor3 = Color3.new(1, 1, 1)
                btn.MouseButton1Click:Connect(function()
                    Events.RequestUpgradeTool:FireServer(toolName)
                    gui:Destroy()
                end)
            else
                btn.Text = "MAX"
                btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                btn.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
        end

        yOffset = yOffset + 65
    end
end

-- ==========================================
-- SELL MENU UI
-- ==========================================
function ShowSellMenu()
    local existing = playerGui:FindFirstChild("SellUI")
    if existing then existing:Destroy() end

    local data = UIManager:GetPlayerData()
    if not data then return end

    local gui = Instance.new("ScreenGui")
    gui.Name = "SellUI"
    gui.ResetOnSpawn = false
    gui.Parent = playerGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 400, 0, 400)
    bg.Position = UDim2.new(0.5, -200, 0.5, -200)
    bg.BackgroundColor3 = Color3.fromRGB(30, 25, 20)
    bg.BackgroundTransparency = 0.1
    bg.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = bg

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 215, 0)
    stroke.Thickness = 2
    stroke.Parent = bg

    -- Title
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 40)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.fromRGB(255, 215, 0)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 20
    title.Text = "Marcel le Marchand — Vendre"
    title.Parent = bg

    -- Close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 16
    closeBtn.Text = "X"
    closeBtn.Parent = bg
    local closeBtnCorner = Instance.new("UICorner")
    closeBtnCorner.CornerRadius = UDim.new(0, 6)
    closeBtnCorner.Parent = closeBtn
    closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)

    -- Item list
    local EconomyConfig = require(ReplicatedStorage.Modules.Config.EconomyConfig)
    local prices = EconomyConfig.SellPrices.MarchandLocal
    local yOffset = 50

    local displayNames = {
        Paillettes = "Paillettes",
        OrPur = "Or Pur",
        Lingots = "Lingots",
        Pepites = "Pépites",
        MineraiOr = "Minerai d'Or",
        Quartz = "Quartz",
        Amethyste = "Améthyste",
        Topaze = "Topaze",
    }

    for itemName, price in pairs(prices) do
        local qty = data.Inventory[itemName] or 0
        if qty > 0 then
            local row = Instance.new("Frame")
            row.Size = UDim2.new(1, -20, 0, 45)
            row.Position = UDim2.new(0, 10, 0, yOffset)
            row.BackgroundColor3 = Color3.fromRGB(50, 45, 35)
            row.BackgroundTransparency = 0.3
            row.Parent = bg

            local rowCorner = Instance.new("UICorner")
            rowCorner.CornerRadius = UDim.new(0, 6)
            rowCorner.Parent = row

            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(0.5, 0, 1, 0)
            nameLabel.Position = UDim2.new(0, 10, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
            nameLabel.Font = Enum.Font.Gotham
            nameLabel.TextSize = 13
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Text = string.format("%s x%d (%d$/u)", displayNames[itemName] or itemName, qty, price)
            nameLabel.Parent = row

            local sellBtn = Instance.new("TextButton")
            sellBtn.Size = UDim2.new(0, 110, 0, 30)
            sellBtn.Position = UDim2.new(1, -120, 0.5, -15)
            sellBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            sellBtn.TextColor3 = Color3.new(1, 1, 1)
            sellBtn.Font = Enum.Font.GothamBold
            sellBtn.TextSize = 13
            sellBtn.Text = "Vendre tout (" .. (qty * price) .. "$)"
            sellBtn.Parent = row

            local sellBtnCorner = Instance.new("UICorner")
            sellBtnCorner.CornerRadius = UDim.new(0, 6)
            sellBtnCorner.Parent = sellBtn

            sellBtn.MouseButton1Click:Connect(function()
                Events.RequestSell:FireServer("MarchandLocal", itemName, qty)
                gui:Destroy()
            end)

            yOffset = yOffset + 52
        end
    end

    -- Message si inventaire vide
    if yOffset == 50 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, -20, 0, 40)
        emptyLabel.Position = UDim2.new(0, 10, 0, 60)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        emptyLabel.Font = Enum.Font.Gotham
        emptyLabel.TextSize = 14
        emptyLabel.Text = "Tu n'as rien à vendre pour le moment !"
        emptyLabel.Parent = bg
    end
end

-- ==========================================
-- RÉSULTATS SERVEUR
-- ==========================================
Events.ShopResult.OnClientEvent:Connect(function(success, message)
    UIManager:ShowNotification(message, success and "Success" or "Error")
    UIManager:RefreshHUD()
end)

Events.SellResult.OnClientEvent:Connect(function(success, message)
    UIManager:ShowNotification(message, success and "Success" or "Error")
    UIManager:RefreshHUD()
end)

print("[InteractionClient] Initialisé ✓")
]]></string>
